{
  "name": "agentic-bdd-flowctl",
  "version": "0.2.0",
  "description": "A source-grounded compiler from React/Java evidence to happy-path BDD and Playwright execution manifests.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TarunKurella/agentic-bdd-flowctl.git"
  },
  "homepage": "https://github.com/TarunKurella/agentic-bdd-flowctl#readme",
  "bugs": {
    "url": "https://github.com/TarunKurella/agentic-bdd-flowctl/issues"
  },
  "keywords": [
    "bdd",
    "playwright",
    "react",
    "spring",
    "agentic-testing",
    "source-analysis"
  ],
  "type": "module",
  "bin": {
    "flowctl": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "schemas",
    ".agents/skills/agentic-bdd/SKILL.md",
    "flowctl.config.example.yaml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/cli.ts",
    "check": "npm run typecheck && npm run test && npm run build",
    "check:package": "node scripts/check-package.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "node --import tsx src/cli.ts analyze --config examples/account-opening/flowctl.config.yaml --through coverage",
    "demo:bdd": "node --import tsx src/cli.ts bdd generate --config examples/account-opening/flowctl.config.yaml"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "overrides": {
    "lodash": "4.18.1",
    "lodash-es": "4.18.1"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.44.1",
    "commander": "15.0.0",
    "fast-glob": "3.3.3",
    "java-parser": "3.0.1",
    "ts-morph": "28.0.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "^26.1.1",
    "playwright-bdd": "9.2.0",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
