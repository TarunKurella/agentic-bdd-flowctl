{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentic-bdd/agent-operation-proposal-v1.schema.json",
  "title": "Operation semantic proposal",
  "type": "object",
  "required": ["packetId", "decisions", "unresolved"],
  "properties": {
    "packetId": { "type": "string" },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["operationId", "label", "machineName", "aliases", "explanation", "evidenceRefs"],
        "properties": {
          "operationId": { "type": "string" },
          "label": { "type": "string", "minLength": 1 },
          "machineName": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "familyHint": { "type": "string" },
          "explanation": { "type": "string", "minLength": 1 },
          "evidenceRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "unresolved": { "type": "array" }
  },
  "additionalProperties": false
}
