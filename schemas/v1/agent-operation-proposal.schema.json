{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowctl.dev/schemas/v1/agent-operation-proposal.schema.json",
  "title": "Operation semantic proposal",
  "type": "object",
  "required": ["packetId", "packetDigest", "decisions"],
  "properties": {
    "packetId": { "type": "string", "minLength": 1 },
    "packetDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["operationId", "label", "machineName", "explanation", "evidenceRefs"],
        "properties": {
          "operationId": { "type": "string" },
          "label": { "type": "string", "minLength": 1 },
          "machineName": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "familyHint": { "type": "string" },
          "explanation": { "type": "string", "minLength": 1 },
          "evidenceRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "unresolved": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "evidenceRefs"],
        "properties": {
          "operationId": { "type": "string" },
          "question": { "type": "string", "minLength": 1 },
          "evidenceRefs": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "additionalProperties": false
}
