{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowctl.dev/schemas/v1/agent-rule-proposal.schema.json",
  "title": "Operation rule proposal",
  "type": "object",
  "required": ["packetId", "packetDigest", "resolutions"],
  "properties": {
    "packetId": { "type": "string", "minLength": 1 },
    "packetDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "resolutions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["endpointId", "explanation", "evidenceRefs"],
        "properties": {
          "endpointId": { "type": "string" },
          "authorization": {
            "oneOf": [
              { "type": "object", "required": ["status"], "properties": { "status": { "const": "anonymous" } }, "additionalProperties": false },
              { "type": "object", "required": ["status"], "properties": { "status": { "const": "authenticated" } }, "additionalProperties": false },
              { "type": "object", "required": ["status", "authoritiesAll"], "properties": { "status": { "const": "exact" }, "authoritiesAll": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } }, "additionalProperties": false }
            ]
          },
          "successPredicateExpression": { "type": "string", "minLength": 1 },
          "explanation": { "type": "string", "minLength": 1 },
          "evidenceRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "unresolved": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "evidenceRefs"],
        "properties": {
          "endpointId": { "type": "string" },
          "question": { "type": "string", "minLength": 1 },
          "evidenceRefs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
