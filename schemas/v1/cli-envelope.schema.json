{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowctl.dev/schemas/v1/cli-envelope.schema.json",
  "title": "Flowctl CLI envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "command", "ok", "code", "nextActions", "diagnostics", "agent"],
  "properties": {
    "schemaVersion": { "const": "flowctl.cli.v1" },
    "command": { "type": "string", "minLength": 1 },
    "ok": { "type": "boolean" },
    "code": { "type": "string", "minLength": 1 },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "configPath"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "configPath": { "type": "string", "minLength": 1 },
        "sourceDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "familyId": { "type": "string" },
        "variantId": { "type": "string" },
        "environment": { "type": "string" }
      }
    },
    "result": {},
    "nextActions": { "type": "array", "items": { "$ref": "#/$defs/action" } },
    "diagnostics": { "type": "array", "items": { "$ref": "#/$defs/diagnostic" } },
    "agent": { "$ref": "#/$defs/agentDirective" }
  },
  "$defs": {
    "agentDirective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "directiveId", "disposition", "stateCode", "objective", "instruction", "selectionRule", "afterAction", "retryPolicy", "stopConditions", "guardrails"],
      "properties": {
        "schemaVersion": { "const": "flowctl.agent.v1" },
        "directiveId": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "disposition": { "enum": ["execute", "inspect", "stop-for-human", "complete"] },
        "stateCode": { "type": "string", "minLength": 1 },
        "objective": { "type": "string", "minLength": 1 },
        "instruction": { "type": "string", "minLength": 1 },
        "selectionRule": { "type": "string", "minLength": 1 },
        "primaryAction": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "executor", "command", "reason"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "executor": { "enum": ["agent", "human"] },
            "command": { "type": "string", "minLength": 1 },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        "afterAction": {
          "type": "object",
          "additionalProperties": false,
          "required": ["expectedStateChange", "resumeCommand", "ifStateUnchanged"],
          "properties": {
            "expectedStateChange": { "type": "string", "minLength": 1 },
            "resumeCommand": { "type": "string", "minLength": 1 },
            "ifStateUnchanged": { "type": "string", "minLength": 1 }
          }
        },
        "retryPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed", "maxAttemptsWithoutStateChange", "requiresStateChangeBeforeRepeat"],
          "properties": {
            "allowed": { "type": "boolean" },
            "maxAttemptsWithoutStateChange": { "type": "integer", "minimum": 0, "maximum": 1 },
            "requiresStateChangeBeforeRepeat": { "type": "boolean" }
          }
        },
        "stopConditions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "guardrails": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "executor", "title", "reason", "command", "blocking"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["compiler", "agent", "review", "data", "bdd", "runtime", "inspect"] },
        "executor": { "enum": ["agent", "human"] },
        "title": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "blocking": { "type": "boolean" },
        "followUpCommands": { "type": "array", "items": { "type": "string" } },
        "packet": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "path", "outputPath"],
          "properties": {
            "id": { "type": "string" },
            "path": { "type": "string" },
            "outputPath": { "type": "string" }
          }
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["info", "warning", "error", "blocked"] },
        "message": { "type": "string", "minLength": 1 },
        "evidenceRefs": { "type": "array", "items": { "type": "string" } },
        "scope": { "type": "string" }
      }
    }
  }
}
