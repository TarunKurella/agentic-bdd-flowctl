{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowctl.dev/schemas/v1/artifact-envelope.schema.json",
  "title": "Flowctl artifact envelope",
  "type": "object",
  "required": ["meta", "data"],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "artifactType",
        "schemaVersion",
        "producer",
        "producerVersion",
        "sourceDigest",
        "configDigest",
        "inputDigests",
        "contentDigest",
        "envelopeDigest",
        "status",
        "unresolved"
      ],
      "properties": {
        "artifactType": { "type": "string", "minLength": 1 },
        "schemaVersion": { "const": "1.0" },
        "producer": { "type": "string", "minLength": 1 },
        "producerVersion": { "type": "string", "minLength": 1 },
        "sourceDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "configDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "inputDigests": { "type": "object", "additionalProperties": { "type": "string" } },
        "contentDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "envelopeDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "status": {
          "enum": ["raw", "proposed", "validated", "reviewed", "generated", "grounded", "verified", "stale"]
        },
        "unresolved": { "type": "array" }
      },
      "additionalProperties": false
    },
    "data": {}
  },
  "additionalProperties": false
}
